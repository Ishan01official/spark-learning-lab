flowchart TB
    App["Spark Application<br/>(1 SparkSession, runs until spark.stop())"]
    App --> J1["Job 1<br/>(triggered by action #1)"]
    App --> J2["Job 2<br/>(triggered by action #2)"]

    J1 --> S1["Stage 0<br/>(scan + filter + select)"]
    J1 --> S2["Stage 1<br/>(after shuffle: groupBy)"]
    J1 --> S3["Stage 2<br/>(after shuffle: orderBy)"]

    S1 --> T1["Task 0"]
    S1 --> T2["Task 1"]
    S1 --> T3["..."]
    S1 --> T4["Task N-1<br/>(N = partition count)"]

    S2 --> U1["Task 0"]
    S2 --> U2["..."]

    style App fill:#1f2937,color:#fff
    style J1 fill:#3b82f6,color:#fff
    style J2 fill:#3b82f6,color:#fff
    style S1 fill:#10b981,color:#fff
    style S2 fill:#10b981,color:#fff
    style S3 fill:#10b981,color:#fff
